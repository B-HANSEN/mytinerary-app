{
  "name": "mytinerary-app",
  "version": "2.0.0",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "description": "",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "setup": "npm install && npm install --prefix client --legacy-peer-deps",
    "seed": "node seed.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node server.js",
    "client": "npm start --prefix client",
    "server": "nodemon server.js",
    "dev": "concurrently --kill-others-on-fail \"npm run server\" \"npm run client\"",
    "build": "npm install --prefix client --legacy-peer-deps && npm run build --prefix client",
    "heroku-postbuild": "NPM_CONFIG_PRODUCTION=false npm install --prefix client && npm run build --prefix client"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/B-HANSEN/mytinerary-app.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/B-HANSEN/mytinerary-app/issues"
  },
  "homepage": "https://github.com/B-HANSEN/mytinerary-app#readme",
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "bcryptjs": "^3.0.3",
    "config": "^4.4.1",
    "hono": "^4.6.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "nodemon": "^3.0.0",
    "prettier": "^3.8.2"
  }
}
