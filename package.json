{
  "name": "mytinerary-app",
  "version": "1.0.0",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "description": "",
  "main": "server.js",
  "scripts": {
    "setup": "npm install && npm install --prefix client",
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node server.js",
    "client": "npm start --prefix client",
    "server": "nodemon server.js",
    "dev": "concurrently --kill-others-on-fail \"npm run server\" \"npm run client\"",
    "build": "npm run build --prefix client",
    "heroku-postbuild": "NPM_CONFIG_PRODUCTION=false npm install --prefix client && npm run build --prefix client"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/B-HANSEN/mytinerary-app.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/B-HANSEN/mytinerary-app/issues"
  },
  "homepage": "https://github.com/B-HANSEN/mytinerary-app#readme",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "config": "^3.2.2",
    "dotenv": "^8.1.0",
    "express": "^4.17.1",
    "jsonwebtoken": "^8.5.1",
    "mongodb": "^3.3.0-beta2",
    "mongoose": "^5.6.7",
    "multer": "^1.4.2",
    "react-router-last-location": "^2.0.1"
  },
  "devDependencies": {
    "concurrently": "^4.0.1",
    "nodemon": "^3.0.0"
  }
}
